OCSR_DEVICE=cuda:0
DECIMER_DEVICE=gpu
OCSR_STRICT_MODE=true
DECIMER_STRICT_MODE=true
OCSR_GPU_REQUIRED=true
OCSR_GPU_MAX_CONCURRENT_INFERENCE=1
OCSR_ENSEMBLE_PARALLEL=false
